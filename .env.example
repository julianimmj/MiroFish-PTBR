# Configuração da API LLM (suporta qualquer API LLM no formato OpenAI SDK)
# Recomendado: plataforma Alibaba Bailian com modelo qwen-plus: https://bailian.console.aliyun.com/
# Atenção: o consumo pode ser alto. Comece com menos de 40 rodadas de simulação
LLM_API_KEY=sua_chave_api_aqui
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# ===== Configuração de Memória de Grafo ZEP =====
# A cota gratuita mensal é suficiente para uso simples: https://app.getzep.com/
ZEP_API_KEY=sua_chave_zep_aqui

# ===== Configuração LLM Acelerada (Opcional) =====
# Se não usar configuração acelerada, não inclua as variáveis abaixo no arquivo .env
LLM_BOOST_API_KEY=sua_chave_api_aqui
LLM_BOOST_BASE_URL=sua_url_base_aqui
LLM_BOOST_MODEL_NAME=nome_do_modelo_aqui